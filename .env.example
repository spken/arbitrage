# ── Wallet ────────────────────────────────────────────────────────────────────
# MetaMask: Settings → Security & Privacy → Export Private Key
# NEVER commit this file. NEVER share this value.
PRIVATE_KEY=0x_YOUR_PRIVATE_KEY_HERE

# ── Polymarket CLOB API ───────────────────────────────────────────────────────
# Generate at: https://docs.polymarket.com/#authentication
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=

# ── Polygon RPC ───────────────────────────────────────────────────────────────
# Free: https://www.alchemy.com → New App → Polygon Mainnet → copy HTTPS URL
POLYGON_RPC=https://polygon-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# ── Capital ───────────────────────────────────────────────────────────────────
# Match this to your actual Polymarket USDC balance
STARTING_CAPITAL=100
